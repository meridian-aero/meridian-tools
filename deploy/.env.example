# Hangar Production Environment
# Copy to .env and fill in real values.

# ---------- Keycloak ----------
KC_DB_PASSWORD=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KC_HOSTNAME=auth.lakesideai.dev

# ---------- Shared auth ----------
OIDC_ISSUER_URL=https://auth.lakesideai.dev/realms/hangar

# ---------- OAS MCP ----------
OAS_OIDC_CLIENT_ID=oas-mcp
OAS_OIDC_CLIENT_SECRET=
OAS_RESOURCE_SERVER_URL=https://mcp.lakesideai.dev/oas

# ---------- OCP MCP ----------
OCP_OIDC_CLIENT_ID=ocp-mcp
OCP_OIDC_CLIENT_SECRET=
OCP_RESOURCE_SERVER_URL=https://mcp.lakesideai.dev/ocp

# ---------- PYC MCP ----------
PYC_OIDC_CLIENT_ID=pyc-mcp
PYC_OIDC_CLIENT_SECRET=
PYC_RESOURCE_SERVER_URL=https://mcp.lakesideai.dev/pyc

# ---------- Viewer (optional, OIDC mode) ----------
# HANGAR_VIEWER_OIDC_CLIENT_ID=hangar-viewer
# HANGAR_VIEWER_OIDC_CLIENT_SECRET=
# HANGAR_VIEWER_SESSION_SECRET=          # generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# HANGAR_VIEWER_ADMIN_ROLE=oas-admin

# ---------- Viewer (optional, Basic Auth fallback) ----------
# HANGAR_VIEWER_USER=admin
# HANGAR_VIEWER_PASSWORD=

# ---------- Logging ----------
# HANGAR_LOG_LEVEL=INFO
